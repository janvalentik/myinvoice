.git
.gitignore
.vscode
.claude
.idea

# Root-level docs (manual/*.md MUST stay — generateManualHtml.php čte z nich)
/README.md
/CHANGELOG.md
/source

# Will be rebuilt inside image
api/vendor
web/node_modules
web/dist
manual/generated
manual/manual.pdf

# Lokální build artefakty / vývojové věci — do image nepatří (šetří kontext i velikost).
# `dist/` je lokální výstup release-bundle testů (gitignored, ~100 MB) — bez tohohle
# řádku by ho `COPY . .` přibalil do /var/www/html/dist.
dist
api/vendor.prod
api/tests
api/.phpunit.cache
.github

# Local-only — secrets, NESMÍ se dostat do image (vše se čte z hostu:
# .env přes compose var-substituci, cfg.docker.php přes read-only bind-mount).
cfg.php
cfg.local.php
cfg.docker.php
.env
.env.*
log
storage
private
aspnet_client

# IIS config — Docker image servíruje přes nginx (alpine) / .htaccess (Debian fallback)
web.config

# Jednorázový externí migrační nástroj (Money S3) — runtime ho nespouští, do image nepatří
tools/money-s3-import

# Build artefacts
*.log
.DS_Store
Thumbs.db
