{# MyInvoice.cz — PDF šablona PŘIJATÉ faktury (mPDF + Twig) #}
{# Variables: invoice, vendor, our_company, items, totals, currency, doc_type_label, locale #}
<!doctype html>
<html lang="{{ locale|default('cs') }}">
<head>
<meta charset="utf-8">
<title></title>
<style>{{ css|raw }}</style>
</head>
<body>

{# ─── PAGE FOOTER ─── #}
<htmlpagefooter name="attribution">
  <div class="page-attribution">
    {% if locale == 'en' %}Reconstruction generated by <a href="https://myinvoice.cz/">MyInvoice.cz</a> — original from vendor is authoritative{% else %}Rekonstrukce vygenerována systémem <a href="https://myinvoice.cz/">MyInvoice.cz</a> — originál od dodavatele je závazný dokument{% endif %}
  </div>
</htmlpagefooter>
<sethtmlpagefooter name="attribution" value="on" />

{# ─── HLAVIČKA ─── #}
<table class="head{% if invoice.document_kind == 'credit_note' %} credit-note{% endif %}">
  <tr>
    <td class="logo">
      <div class="brand-name">{{ vendor.company_name }}</div>
      <div class="reconstruction-badge">{% if locale == 'en' %}Reconstruction{% else %}Rekonstrukce{% endif %}</div>
    </td>
    <td class="meta">
      <div class="doc-type">{{ doc_type_label }}</div>
      {% if invoice.vendor_invoice_number %}
        <div class="varsymbol-big">{{ invoice.vendor_invoice_number }}</div>
      {% endif %}
      {% if invoice.varsymbol %}
        <div class="parent-ref">{% if locale == 'en' %}our ref{% else %}naše ozn.{% endif %}: {{ invoice.varsymbol }}</div>
      {% endif %}
    </td>
  </tr>
</table>

{# ─── STRANY ─── #}
<table class="parties">
  <tr>
    <td>
      <h2>{% if locale == 'en' %}Supplier (vendor){% else %}Dodavatel{% endif %}</h2>
      <div class="spacer-3">&nbsp;</div>
      <div class="party-name">{{ vendor.company_name }}</div>
      <div>{{ vendor.street }}</div>
      <div>{{ vendor.zip }} {{ vendor.city }}</div>
      <div>{{ vendor.country_iso2 }}</div>
      <div class="spacer-4">&nbsp;</div>
      <div class="ic-dic">
        {# Národní daňové číslo dodavatele (#120): SK DIČ / DE+AT Steuernummer / PL NIP /
           HU Adószám s nativním labelem; `dic` = VAT ID s prefixem (u SK = IČ DPH).
           Starší snapshoty tax_number nemají → u SK odvození z IČ DPH oseknutím prefixu. #}
        {% set tax_no_labels = {'SK': 'DIČ', 'DE': 'Steuernummer', 'AT': 'Steuernummer', 'PL': 'NIP', 'HU': 'Adószám'} %}
        {% set vendor_dic_sk = vendor.dic and (vendor.dic|upper starts with 'SK') %}
        {% set vendor_tax_no = vendor.tax_number|default(vendor_dic_sk ? vendor.dic|slice(2) : '') %}
        {% if vendor.ic %}{% if locale == 'en' %}Reg. No.{% else %}IČO{% endif %}: {{ vendor.ic }}<br>{% endif %}
        {% if vendor_tax_no %}
          {{ tax_no_labels[vendor.country_iso2|default('')]|default(vendor_dic_sk ? 'DIČ' : (locale == 'en' ? 'Tax No.' : 'Daňové číslo')) }}: {{ vendor_tax_no }}{% if vendor.dic %}<br>{% endif %}
        {% endif %}
        {% if vendor.dic %}
          {% if vendor_dic_sk %}{{ locale == 'en' ? 'VAT ID' : 'IČ DPH' }}{% else %}{{ locale == 'en' ? 'VAT ID' : 'DIČ' }}{% endif %}: {{ vendor.dic }}
        {% endif %}
      </div>
    </td>
    <td>
      <h2>{% if locale == 'en' %}Customer (us){% else %}Odběratel (my){% endif %}</h2>
      <div class="spacer-3">&nbsp;</div>
      <div class="party-name">{{ our_company.company_name }}</div>
      <div>{{ our_company.street }}</div>
      <div>{{ our_company.zip }} {{ our_company.city }}</div>
      <div>{{ our_company.country_iso2 }}</div>
      <div class="spacer-4">&nbsp;</div>
      <div class="ic-dic">
        {% if our_company.ic %}{% if locale == 'en' %}Reg. No.{% else %}IČO{% endif %}: {{ our_company.ic }}<br>{% endif %}
        {% if our_company.dic %}
          {% if our_company.dic|upper starts with 'SK' %}
            {% if locale == 'en' %}Tax ID{% else %}DIČ{% endif %}: {{ our_company.dic|slice(2) }}<br>
            {% if locale == 'en' %}VAT ID{% else %}IČ DPH{% endif %}: {{ our_company.dic }}
          {% else %}
            {% if locale == 'en' %}VAT ID{% else %}DIČ{% endif %}: {{ our_company.dic }}
          {% endif %}
        {% endif %}
      </div>
    </td>
  </tr>
</table>

{# ─── META INFO (dates + currency) ─── #}
<table class="meta-info">
  <tr>
    <td>
      <span class="label">{% if locale == 'en' %}Issue date{% else %}Vystaveno{% endif %}</span>
      <span class="value">{{ invoice.issue_date|date('j. n. Y') }}</span>
    </td>
    <td>
      <span class="label">{% if locale == 'en' %}Tax point{% else %}DUZP{% endif %}</span>
      <span class="value">{% if invoice.tax_date %}{{ invoice.tax_date|date('j. n. Y') }}{% else %}—{% endif %}</span>
    </td>
    <td>
      <span class="label">{% if locale == 'en' %}Due date{% else %}Splatnost{% endif %}</span>
      <span class="value">{% if invoice.due_date %}{{ invoice.due_date|date('j. n. Y') }}{% else %}—{% endif %}</span>
    </td>
    <td>
      <span class="label">{% if locale == 'en' %}Currency{% else %}Měna{% endif %}</span>
      <span class="value">{{ currency }}</span>
    </td>
  </tr>
</table>

{% if invoice.reverse_charge %}
<div class="rc-note">
  <strong>{% if locale == 'en' %}Reverse charge — VAT paid by customer.{% else %}Daň odvádí zákazník (přenesená daňová povinnost).{% endif %}</strong>
</div>
{% endif %}

{% if invoice.note_above_items %}
<div class="note-above">{{ invoice.note_above_items|nl2br }}</div>
{% endif %}

{# ─── POLOŽKY ─── #}
<table class="items">
  <thead>
    <tr>
      <th class="num">#</th>
      <th>{% if locale == 'en' %}Description{% else %}Popis{% endif %}</th>
      <th class="num">{% if locale == 'en' %}Qty{% else %}Množ.{% endif %}</th>
      <th class="num">{% if locale == 'en' %}Unit price{% else %}Cena/j{% endif %}</th>
      <th class="num">DPH</th>
      <th class="num">{% if invoice.prices_include_vat %}{% if locale == 'en' %}Total inc. VAT{% else %}Celkem s DPH{% endif %}{% else %}{% if locale == 'en' %}Total ex. VAT{% else %}Celkem bez DPH{% endif %}{% endif %}</th>
    </tr>
  </thead>
  <tbody>
    {% for item in items %}
    <tr>
      <td class="num">{{ loop.index }}.</td>
      <td>{{ item.description }}</td>
      <td class="num">{{ item.quantity|number_format(2, ',', ' ') }} {{ item.unit|default('ks') }}</td>
      <td class="num">{{ item.unit_price_without_vat|number_format(2, ',', ' ') }} {{ currency }}</td>
      <td class="num">{{ item.vat_rate|number_format(0) }}%</td>
      <td class="num">{{ item.line_total|number_format(2, ',', ' ') }} {{ currency }}</td>
    </tr>
    {% else %}
    <tr><td colspan="6" class="empty">{% if locale == 'en' %}No items{% else %}Žádné položky{% endif %}</td></tr>
    {% endfor %}
  </tbody>
</table>

{# ─── TOTALS ─── #}
<table class="totals">
  <tr>
    <td class="label">{% if locale == 'en' %}Subtotal{% else %}Celkem bez DPH{% endif %}</td>
    <td class="num">{{ totals.without_vat|number_format(2, ',', ' ') }} {{ currency }}</td>
  </tr>
  <tr>
    <td class="label">{% if locale == 'en' %}VAT total{% else %}DPH celkem{% endif %}</td>
    <td class="num">{{ totals.vat|number_format(2, ',', ' ') }} {{ currency }}</td>
  </tr>
  <tr class="grand">
    <td class="label">{% if locale == 'en' %}Total inc. VAT{% else %}Celkem k úhradě{% endif %}</td>
    <td class="num">{{ totals.with_vat|number_format(2, ',', ' ') }} {{ currency }}</td>
  </tr>
</table>

{% if invoice.note_below_items %}
<div class="note-below">{{ invoice.note_below_items|nl2br }}</div>
{% endif %}

</body>
</html>
