{# MyInvoice.cz — PDF šablona faktury (mPDF + Twig) #}
{# Variables: invoice (full hydrated), supplier, client, bank, qr_data_uri, locale #}
<!doctype html>
<html lang="{{ locale|default('cs') }}">
<head>
<meta charset="utf-8">
<title></title>
<style>{{ css|raw }}</style>
</head>
<body>

{# ─── PAGE FOOTER (každá stránka) — attribution ─── #}
<htmlpagefooter name="attribution">
  <div class="page-attribution">
    {% if locale == 'en' %}Powered by <a href="https://myinvoice.cz/">MyInvoice.cz</a> invoicing system by <a href="https://mywebdesign.cz/">MyWebdesign.cz</a>{% else %}Používá fakturační systém <a href="https://myinvoice.cz/">MyInvoice.cz</a> od <a href="https://mywebdesign.cz/">MyWebdesign.cz</a>{% endif %}
  </div>
</htmlpagefooter>
<sethtmlpagefooter name="attribution" value="on" />

{# ─── HLAVIČKA ─── #}
<table class="head{% if invoice.invoice_type == 'credit_note' %} credit-note{% elseif invoice.invoice_type == 'cancellation' %} cancellation{% endif %}">
  <tr>
    {% if logo_show_name and logo_path and logo_path is not empty %}
      {# Logo + název firmy: dvě SOUSEDNÍ buňky .head (žádná vnořená tabulka — ta v mPDF
         mazala spodní čáru hlavičky). Mezeru dělá pevná šířka buňky loga: mPDF na buňce
         respektuje `width`, ne padding. #}
      <td class="logo-img-cell"><img src="{{ logo_path }}" alt="logo"></td>
      <td class="logo-name">{{ supplier.display_name|default(supplier.company_name) }}</td>
    {% else %}
      <td class="logo">
        {% if logo_path and logo_path is not empty %}
          <img src="{{ logo_path }}" alt="logo" style="max-width: 72mm; max-height: 20mm;">
        {% else %}
          <div class="brand-name">{{ supplier.company_name }}</div>
        {% endif %}
      </td>
    {% endif %}
    <td class="meta">
      <div class="doc-type">{{ doc_type_label }}</div>
      {% if invoice.varsymbol %}
        <div class="varsymbol-big">{{ invoice.varsymbol }}</div>
      {% endif %}
      {% if parent_varsymbol %}
        <div class="parent-ref">{{ t('k faktuře', 'to invoice') }} {{ parent_varsymbol }}</div>
      {% endif %}
      {% if isdoc_attachment %}
        {# Vizuální badge — samotný embedded ISDOC soubor přidává mPDF přes
           SetAssociatedFiles() v PDF/A-3 /AF + /Names /EmbeddedFiles. Klikatelná
           paperclip annotation tady BYLA, ale duplikovala přílohu pod sanitizovaným
           filename (mPDF si dělá embed lokálně z file= cesty), takže ji zde nemáme. #}
        <div class="isdoc-badge">ISDOC</div>
      {% endif %}
    </td>
  </tr>
</table>

{# ─── STRANY ─── #}
<table class="parties">
  <tr>
    <td>
      <h2>{{ t('Dodavatel', 'Supplier') }}</h2>
      <div class="spacer-3">&nbsp;</div>
      <div class="party-name">{{ supplier.company_name }}</div>
      {% if supplier.display_name and supplier.display_name != supplier.company_name %}
        <div>{{ supplier.display_name }}</div>
      {% endif %}
      <div>{{ supplier.street }}</div>
      <div>{{ supplier.zip }} {{ supplier.city }}</div>
      <div>{{ locale == 'en' ? supplier.country_name_en : supplier.country_name_cs }}</div>
      <div class="spacer-4">&nbsp;</div>
      <div class="ic-dic">
        {% if supplier.ic %}{{ t('IČO', 'Reg. No.') }}: {{ supplier.ic }}<br>{% endif %}
        {# SK plátce DPH (#120): DIČ s prefixem SK je „IČ DPH"; vedle něj patří DIČ = totéž bez
           prefixu (supplier skdic nevede, SK DIČ se od IČ DPH liší jen prefixem). Neplátce má
           v poli jen číslo bez prefixu → spadne do else a tiskne se jako DIČ. #}
        {% if supplier.dic %}
          {% if supplier.dic|upper starts with 'SK' %}
            {{ t('DIČ', 'Tax ID') }}: {{ supplier.dic|slice(2) }}<br>
            {{ t('IČ DPH', 'VAT ID') }}: {{ supplier.dic }}
          {% else %}
            {{ t('DIČ', 'VAT ID') }}: {{ supplier.dic }}
          {% endif %}
        {% endif %}
      </div>
    </td>
    <td>
      <h2>{{ t('Odběratel', 'Customer') }}</h2>
      <div class="spacer-3">&nbsp;</div>
      <div class="party-name">{{ client.company_name }}</div>
      {% if client.first_name or client.last_name %}
        <div>{{ client.first_name }} {{ client.last_name }}</div>
      {% endif %}
      <div>{{ client.street }}</div>
      <div>{{ client.zip }} {{ client.city }}</div>
      <div>{{ locale == 'en' ? client.country_name_en : client.country_name_cs }}</div>
      <div class="spacer-4">&nbsp;</div>
      <div class="ic-dic">
        {# Národní daňové číslo (#120): SK DIČ / DE+AT Steuernummer / PL NIP / HU Adószám —
           nativní label podle země klienta. `dic` zůstává VAT ID s prefixem (u SK = IČ DPH,
           u SK se proto VAT řádek labeluje „IČ DPH"). Pořadí dle SK praxe: IČO, DIČ, IČ DPH.
           Starší SK snapshoty tax_number nemají → odvodíme z IČ DPH oseknutím prefixu
           (SK DIČ se od IČ DPH liší jen prefixem; u DE/PL/HU odvodit nejde). #}
        {% set tax_no_labels = {'SK': 'DIČ', 'DE': 'Steuernummer', 'AT': 'Steuernummer', 'PL': 'NIP', 'HU': 'Adószám'} %}
        {% set client_dic_sk = client.dic and (client.dic|upper starts with 'SK') %}
        {% set client_tax_no = client.tax_number|default(client_dic_sk ? client.dic|slice(2) : '') %}
        {% if client.ic %}{{ t('IČO', 'Reg. No.') }}: {{ client.ic }}<br>{% endif %}
        {% if client_tax_no %}
          {{ tax_no_labels[client.country_iso2|default('')]|default(client_dic_sk ? 'DIČ' : t('Daňové číslo', 'Tax No.')) }}: {{ client_tax_no }}{% if client.dic %}<br>{% endif %}
        {% endif %}
        {% if client.dic %}
          {{ client_dic_sk ? t('IČ DPH', 'VAT ID') : t('DIČ', 'VAT ID') }}: {{ client.dic }}
        {% endif %}
      </div>
    </td>
  </tr>
</table>

{# ─── METADATA ─── #}
<table class="meta-grid">
  <tr>
    <td class="meta-label">{{ t('Vystaveno', 'Issued') }}</td>
    <td class="meta-value">{{ invoice.issue_date|date(date_format) }}</td>
    <td class="meta-label">{{ t('Var. symbol', 'Var. symbol') }}</td>
    <td class="meta-value mono">{{ payment_varsymbol|default(invoice.varsymbol)|default('—') }}</td>
  </tr>
  {# Identifikovaná osoba (§ 6g–6l, #94) na zahraničním RC dokladu řádek
     „Není plátce DPH" nemá — matl by příjemce, který má daň samovyměřit;
     nahrazuje ho RC klauzule + DIČ. Tuzemské faktury IO řádek mají (pravdivý). #}
  {% if not supplier.is_vat_payer and not (supplier.is_identified|default(false) and invoice.reverse_charge) %}
  <tr>
    <td class="meta-label">{{ t('DPH', 'VAT') }}</td>
    <td class="meta-value" colspan="3">{{ t('Není plátce DPH', 'Not a VAT payer') }}</td>
  </tr>
  {% elseif supplier.is_vat_payer and invoice.tax_date and invoice.invoice_type != 'proforma' %}
  <tr>
    <td class="meta-label">{{ t('DUZP', 'Tax point') }}</td>
    <td class="meta-value">{{ invoice.tax_date|date(date_format) }}</td>
    <td class="meta-label">{{ t('KS', 'Const. symbol') }}</td>
    <td class="meta-value mono">0308</td>
  </tr>
  {% endif %}
  <tr>
    <td class="meta-label">{{ t('Splatnost', 'Due') }}</td>
    <td class="meta-value">{{ invoice.due_date|date(date_format) }}</td>
    <td class="meta-label">{{ t('Měna', 'Currency') }}</td>
    <td class="meta-value mono">{{ invoice.currency }}</td>
  </tr>
  <tr>
    <td class="meta-label">{{ t('Úhrada', 'Payment') }}</td>
    <td class="meta-value">
      {%- if payment_method == 'card' -%}{{ t('Platební karta', 'Card') }}
      {%- elseif payment_method == 'cash' -%}{{ t('Hotově', 'Cash') }}
      {%- elseif payment_method == 'other' -%}{{ t('Jiný způsob', 'Other') }}
      {%- else -%}{{ t('Bankovní převod', 'Bank transfer') }}{%- endif -%}
    </td>
    {% if invoice.project_name %}
      <td class="meta-label">{{ t('Zakázka', 'Project') }}</td>
      <td class="meta-value">{{ invoice.project_name }}</td>
    {% else %}
      <td></td><td></td>
    {% endif %}
  </tr>
  {% if invoice.project_number or invoice.contract_number %}
  <tr>
    {% if invoice.project_number %}
      <td class="meta-label">{{ t('Vaše číslo', 'Your order no.') }}</td>
      <td class="meta-value mono">{{ invoice.project_number }}</td>
    {% else %}
      <td></td><td></td>
    {% endif %}
    {% if invoice.contract_number %}
      <td class="meta-label">{{ t('Vaše smlouva', 'Your contract') }}</td>
      <td class="meta-value mono">{{ invoice.contract_number }}</td>
    {% else %}
      <td></td><td></td>
    {% endif %}
  </tr>
  {% endif %}
</table>

{% if invoice.note_above_items %}
<div class="note">{{ invoice.note_above_items|nl2br }}</div>
{% endif %}

{# ─── POLOŽKY ─── #}
<table class="items">
  <thead>
    <tr>
      {% if supplier.is_vat_payer %}
      <th style="width:30%">{{ t('Popis', 'Description') }}</th>
      <th class="num nowrap" style="width:7%">{{ t('Mn.', 'Qty') }}</th>
      <th class="nowrap" style="width:7%">{{ t('Jed.', 'Unit') }}</th>
      <th class="num nowrap" style="width:13%">{{ t('Cena/j', 'Price/unit') }}</th>
      <th class="center nowrap" style="width:10%">{{ t('DPH', 'VAT') }}</th>
      <th class="num nowrap" style="width:16%">{{ t('Bez DPH', 'Without VAT') }}</th>
      <th class="num nowrap" style="width:17%">{{ t('S DPH', 'With VAT') }}</th>
      {% else %}
      <th style="width:42%">{{ t('Popis', 'Description') }}</th>
      <th class="num nowrap" style="width:9%">{{ t('Mn.', 'Qty') }}</th>
      <th class="nowrap" style="width:8%">{{ t('Jed.', 'Unit') }}</th>
      <th class="num nowrap" style="width:18%">{{ t('Cena/j', 'Price/unit') }}</th>
      {# RC doklad neplátce/IO: částky jsou základ daně (samovyměří odběratel) —
         sloupec to musí říct, neutrální „Celkem" by byl nejednoznačný. #}
      {% if invoice.reverse_charge %}
      <th class="num nowrap" style="width:23%">{{ t('Celkem bez DPH', 'Total excl. VAT') }}</th>
      {% else %}
      <th class="num nowrap" style="width:23%">{{ t('Celkem', 'Total') }}</th>
      {% endif %}
      {% endif %}
    </tr>
  </thead>
  <tbody>
    {% for item in invoice.items %}
    <tr{% if item.item_kind == 'discount' %} class="discount-row"{% endif %}>
      {# Když má faktura výkaz víceprací, je proklikávací (podtržený) odkaz na stránku
         s výkazem JEN položka výkazu — tj. ta, jejíž popis odpovídá názvu výkazu
         (work_report.title), s pojistkou na klíčové slovo „výkaz" / „work report".
         Ostatní položky i slevové řádky zůstávají běžným textem. mPDF dělá interní
         skok na <a name="work-report">. #}
      {%- set _wr_d = item.description|trim|lower -%}
      {%- set _mat_title = work_report.material_title|default('')|trim|lower -%}
      {%- set _is_mat_item = work_report and work_report.material_total > 0 and item.item_kind != 'discount'
            and _mat_title != '' and _wr_d == _mat_title -%}
      {%- set _is_wr_item = work_report and not _is_mat_item and item.item_kind != 'discount'
            and (_wr_d == (work_report.title|default('')|trim|lower)
                 or 'výkaz' in _wr_d or 'work report' in _wr_d) -%}
      <td>
        {%- if _is_wr_item -%}
          <a href="#work-report" class="wr-link">{{ item.description|nl2br }}</a>
        {%- elseif _is_mat_item -%}
          <a href="#work-report-material" class="wr-link">{{ item.description|nl2br }}</a>
        {%- else -%}
          {{ item.description|nl2br }}
        {%- endif -%}
      </td>
      {% if item.item_kind == 'discount' %}
      <td></td><td></td><td></td>
      {% else %}
      <td class="num nowrap">{{ item.quantity|number_format(item.quantity == item.quantity|round(0) ? 0 : 3, decimal_sep, thousand_sep) }}</td>
      <td>{{ item.unit }}</td>
      {# V režimu „ceny s DPH" nese unit_price_without_vat brutto; pro zobrazení dopočítáme
         skutečné netto z řádkového základu (total_without_vat / množství). #}
      <td class="num nowrap">{{ (invoice.prices_include_vat and item.quantity != 0 ? item.total_without_vat / item.quantity : item.unit_price_without_vat)|number_format(2, decimal_sep, thousand_sep) }}</td>
      {% endif %}
      {% if supplier.is_vat_payer %}
      <td class="center nowrap">{{ item.vat_rate_snapshot|number_format(item.vat_rate_snapshot == item.vat_rate_snapshot|round(0) ? 0 : 2, decimal_sep, thousand_sep) }}&nbsp;%</td>
      <td class="num nowrap">{{ item.total_without_vat|number_format(2, decimal_sep, thousand_sep) }}</td>
      <td class="num nowrap">{{ item.total_with_vat|number_format(2, decimal_sep, thousand_sep) }}</td>
      {% else %}
      <td class="num nowrap">{{ item.total_without_vat|number_format(2, decimal_sep, thousand_sep) }}</td>
      {% endif %}
    </tr>
    {% endfor %}
  </tbody>
</table>

{% if invoice.reverse_charge %}
<div class="note rc-note">
  {# Tuzemský RC mezi plátci = § 92a ZDPH; přeshraniční plnění (klient mimo CZ,
     vč. faktur identifikované osoby do EU) = čl. 196 směrnice 2006/112/ES. #}
  {% if client.country_iso2|default('CZ') == 'CZ' %}
  {{ t('Daň odvede zákazník (přenesená daňová povinnost dle § 92a zákona o DPH).',
       'Reverse charge — VAT to be accounted for by the customer.') }}
  {% else %}
  {{ t('Daň odvede zákazník (přenesení daňové povinnosti dle čl. 196 směrnice 2006/112/ES).',
       'Reverse charge — VAT to be accounted for by the customer pursuant to Article 196 of Council Directive 2006/112/EC.') }}
  {% endif %}
</div>
{% endif %}

{# ─── SUMACE + QR/BANK ─── #}
<table class="totals">
  <tr>
    <td class="left">
      <table style="width:100%;border-collapse:collapse;">
        <tr>
          <td style="vertical-align:top;padding-right:3mm;width:33mm;">
            {% if qr_data_uri %}
            <div class="qr-box">
              <img src="{{ qr_data_uri }}" alt="QR" width="105" height="105">
              <div class="qr-label">QR Pay</div>
            </div>
            {% endif %}
          </td>
          <td style="vertical-align:top;">
            {% if is_paid %}
            <table class="bank-frame paid-stamp">
              <tr>
                <td>
                  <div class="bank-label" style="color:#2E7D32;">{{ t('UHRAZENO', 'PAID') }}</div>
                  <div class="spacer-3">&nbsp;</div>
                  <div class="bank-value" style="color:#2E7D32;">
                    {%- if payment_method == 'card' -%}{{ t('Platba kartou online', 'Paid online by card') }}
                    {%- elseif payment_method == 'cash' -%}{{ t('Hotově', 'Cash') }}
                    {%- else -%}{{ t('Neplaťte prosím znovu', 'Do not pay again') }}{%- endif -%}
                  </div>
                  {% if invoice.paid_at %}
                    <div class="spacer-2">&nbsp;</div>
                    <div class="bank-meta-line">{{ t('Datum úhrady', 'Paid on') }}: {{ invoice.paid_at|date(date_format) }}</div>
                  {% endif %}
                </td>
              </tr>
            </table>
            {% elseif payment_method == 'card' %}
            <table class="bank-frame">
              <tr>
                <td>
                  <div class="bank-label">{{ t('Způsob úhrady', 'Payment method') }}</div>
                  <div class="spacer-3">&nbsp;</div>
                  <div class="bank-value">{{ t('Platební karta', 'Card') }}</div>
                  <div class="spacer-2">&nbsp;</div>
                  <div class="bank-meta-line">{{ t('Bankovní převod ani QR se nepoužije.', 'Bank transfer and QR are not used.') }}</div>
                </td>
              </tr>
            </table>
            {% elseif payment_method == 'cash' %}
            <table class="bank-frame">
              <tr>
                <td>
                  <div class="bank-label">{{ t('Způsob úhrady', 'Payment method') }}</div>
                  <div class="spacer-3">&nbsp;</div>
                  <div class="bank-value">{{ t('Hotově', 'Cash') }}</div>
                </td>
              </tr>
            </table>
            {% elseif bank %}
            <table class="bank-frame">
              <tr>
                <td>
                  <div class="bank-label">{{ t('Bankovní spojení', 'Bank account') }}</div>
                  <div class="spacer-3">&nbsp;</div>
                  {% if bank.account_number %}
                    <div class="bank-value">{{ bank.account_number }}{% if bank.bank_code %} / {{ bank.bank_code }}{% endif %}</div>
                  {% endif %}
                  {% if bank.iban %}
                    <div class="bank-value">{{ bank.iban }}</div>
                  {% endif %}
                  {% if bank.bic or bank.bank_name %}
                    <div class="spacer-2">&nbsp;</div>
                  {% endif %}
                  {% if bank.bic %}
                    <div class="bank-meta-line">BIC: {{ bank.bic }}</div>
                  {% endif %}
                  {% if bank.bank_name %}
                    <div class="bank-meta-line">{{ t('Banka', 'Bank') }}: {{ bank.bank_name }}</div>
                  {% endif %}
                </td>
              </tr>
            </table>
            {% endif %}
          </td>
        </tr>
      </table>
    </td>
    <td class="right">
      <table class="totals-table">
        {% if supplier.is_vat_payer and invoice.invoice_type != 'proforma' %}
        {% for b in invoice.vat_breakdown %}
        <tr>
          <td class="tot-label">{{ t('Základ', 'Base') }} {{ b.rate|number_format(b.rate == b.rate|round(0) ? 0 : 2, decimal_sep, thousand_sep) }}&nbsp;%</td>
          <td class="tot-num nowrap">{{ b.base|number_format(2, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
        </tr>
        {% if b.vat > 0 %}
        <tr>
          <td class="tot-label">{{ t('DPH', 'VAT') }} {{ b.rate|number_format(b.rate == b.rate|round(0) ? 0 : 2, decimal_sep, thousand_sep) }}&nbsp;%</td>
          <td class="tot-num nowrap">{{ b.vat|number_format(2, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
        </tr>
        {% endif %}
        {% endfor %}
        {# Souhrn jen při více sazbách; u jediné sazby by jen zopakoval per-sazbové řádky výše #}
        {% if invoice.vat_breakdown|length > 1 %}
        <tr class="subtotal">
          <td class="tot-label">{{ t('Celkem bez DPH', 'Total without VAT') }}</td>
          <td class="tot-num nowrap">{{ invoice.totals.without_vat|number_format(2, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
        </tr>
        <tr class="subtotal">
          <td class="tot-label">{{ t('DPH celkem', 'Total VAT') }}</td>
          <td class="tot-num nowrap">{{ invoice.totals.vat|number_format(2, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
        </tr>
        {% endif %}
        {% endif %}
        <tr class="grand">
          <td class="tot-label">{{ t('Celkem', 'Total') }}</td>
          <td class="tot-num nowrap">{{ invoice.totals.with_vat|number_format(2, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
        </tr>
        {% if invoice.advance_paid_amount > 0 %}
        <tr class="advance">
          {% if invoice.invoice_type == 'tax_document' %}
          {# Daňový doklad k přijaté platbě — „záloha" je sama přijatá platba. #}
          <td class="tot-label">{{ t('Uhrazeno přijatou platbou', 'Settled by payment received') }}</td>
          {% else %}
          <td class="tot-label">{{ t('Odečet zálohy', 'Advance deduction') }}</td>
          {% endif %}
          <td class="tot-num nowrap">−{{ invoice.advance_paid_amount|number_format(2, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
        </tr>
        <tr class="to-pay">
          <td class="tot-label">{{ t('K úhradě', 'Amount due') }}</td>
          <td class="tot-num nowrap">{{ invoice.amount_to_pay|number_format(2, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
        </tr>
        {% endif %}
        {# Částečné úhrady (#89): evidované platby snižují výzvu k platbě — znovu
           stažené PDF nesmí chtít celou částku (QR výše zní na tentýž zbytek). #}
        {% if (invoice.paid_total ?? 0) > 0 and invoice.status != 'paid' %}
        <tr class="advance">
          <td class="tot-label">{{ t('Uhrazeno', 'Paid to date') }}</td>
          <td class="tot-num nowrap">−{{ invoice.paid_total|number_format(2, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
        </tr>
        <tr class="to-pay">
          <td class="tot-label">{{ t('Zbývá uhradit', 'Remaining amount due') }}</td>
          <td class="tot-num nowrap">{{ (invoice.amount_to_pay - invoice.paid_total)|number_format(2, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
        </tr>
        {% endif %}
        {% if invoice.czk_recap %}
        <tr class="rate-note">
          <td colspan="2" class="rate-note-cell">
            {{ t('Kurz ČNB', 'CNB rate') }}:
            {{ invoice.czk_recap.rate|number_format(3, decimal_sep, thousand_sep) }}&nbsp;CZK / 1&nbsp;{{ invoice.currency }}
            ({{ invoice.czk_recap.rate_date }})
          </td>
        </tr>
        {% endif %}
      </table>
    </td>
  </tr>
</table>

{% if invoice.czk_recap %}
<table class="czk-recap">
  <tr>
    <td colspan="2" class="czk-recap-title">
      {{ t('Přepočet do CZK', 'Conversion to CZK') }}
      <span class="czk-recap-rate">
        {{ t('kurz ČNB', 'CNB rate') }}:
        {{ invoice.czk_recap.rate|number_format(3, decimal_sep, thousand_sep) }}&nbsp;CZK / 1&nbsp;{{ invoice.currency }}
        ({{ invoice.czk_recap.rate_date }})
      </span>
    </td>
  </tr>
  {% if supplier.is_vat_payer and invoice.invoice_type != 'proforma' %}
  {% for b in invoice.czk_recap.breakdown %}
  <tr>
    <td class="tot-label">{{ t('Základ', 'Base') }} {{ b.rate|number_format(b.rate == b.rate|round(0) ? 0 : 2, decimal_sep, thousand_sep) }}&nbsp;%</td>
    <td class="tot-num nowrap">{{ b.base_czk|number_format(2, decimal_sep, thousand_sep) }} CZK</td>
  </tr>
  {% if b.vat_czk > 0 %}
  <tr>
    <td class="tot-label">{{ t('DPH', 'VAT') }} {{ b.rate|number_format(b.rate == b.rate|round(0) ? 0 : 2, decimal_sep, thousand_sep) }}&nbsp;%</td>
    <td class="tot-num nowrap">{{ b.vat_czk|number_format(2, decimal_sep, thousand_sep) }} CZK</td>
  </tr>
  {% endif %}
  {% endfor %}
  {# Souhrn jen při více sazbách; u jediné sazby by jen zopakoval per-sazbové řádky výše #}
  {% if invoice.czk_recap.breakdown|length > 1 %}
  <tr class="subtotal">
    <td class="tot-label">{{ t('Celkem bez DPH', 'Total without VAT') }}</td>
    <td class="tot-num nowrap">{{ invoice.czk_recap.total_without_vat_czk|number_format(2, decimal_sep, thousand_sep) }} CZK</td>
  </tr>
  <tr class="subtotal">
    <td class="tot-label">{{ t('DPH celkem', 'Total VAT') }}</td>
    <td class="tot-num nowrap">{{ invoice.czk_recap.total_vat_czk|number_format(2, decimal_sep, thousand_sep) }} CZK</td>
  </tr>
  {% endif %}
  {% endif %}
  <tr class="grand">
    <td class="tot-label">{{ t('Celkem', 'Total') }}</td>
    <td class="tot-num nowrap">{{ invoice.czk_recap.total_with_vat_czk|number_format(2, decimal_sep, thousand_sep) }} CZK</td>
  </tr>
</table>
{% endif %}

{% if invoice.note_below_items %}
<div class="note">{{ invoice.note_below_items|nl2br }}</div>
{% endif %}

{% if invoice.invoice_type == 'proforma' %}
<div class="note proforma-note">
  {{ t('Nejedná se o daňový doklad, ten bude vystaven po připsání platby.',
       'This is not a tax document. The tax document will be issued after payment is received.') }}
</div>
{% endif %}

<div class="footer">
  <span class="footer-name">{{ supplier.company_name }}</span>{% if supplier.web %}<span class="footer-dot">&#160;·&#160;</span><a href="{{ supplier.web }}" class="footer-link">{{ supplier.web|replace({'https://': '', 'http://': ''})|trim('/') }}</a>{% endif %}{% if supplier.email %}<span class="footer-dot">&#160;·&#160;</span>{{ supplier.email }}{% endif %}
</div>
{% if supplier.commercial_register %}
<div class="commercial-register">{{ supplier.commercial_register }}</div>
{% endif %}

{# ─── VÝKAZ VÍCEPRACÍ + VÝKAZ MATERIÁLU — 2. stránka ─── #}
{% set _has_work = work_report and (work_report.items|length) > 0 %}
{% set _has_material = work_report and work_report.material_total > 0 and (work_report.materials|default([])|length) > 0 %}
{% if _has_work or _has_material %}
{% set wr_has_dates = _has_work and (work_report.items|filter(it => it.work_date)|length) > 0 %}
{# Desetinná místa per sloupec: skryj „,00" jen když jsou VŠECHNY hodnoty ve sloupci celé. #}
{% set hours_dec = (_has_work and (work_report.items|filter(it => it.hours != it.hours|round(0))|length) > 0) ? 2 : 0 %}
{% set rate_dec  = (_has_work and (work_report.items|filter(it => it.rate != it.rate|round(0))|length) > 0) ? 2 : 0 %}
{% set total_dec = (_has_work and (work_report.items|filter(it => it.total_amount != it.total_amount|round(0))|length) > 0) ? 2 : 0 %}
{% set _doc_type = (_has_work and _has_material)
      ? t('Výkaz prací a materiálu', 'Work & material report')
      : (_has_work ? t('Výkaz víceprací', 'Work report') : t('Výkaz materiálu', 'Material report')) %}
<div class="page-break"></div>

<table class="head">
  <tr>
    {% if logo_show_name and logo_path and logo_path is not empty %}
      {# Logo + název firmy: dvě SOUSEDNÍ buňky .head (žádná vnořená tabulka — ta v mPDF
         mazala spodní čáru hlavičky). Mezeru dělá pevná šířka buňky loga: mPDF na buňce
         respektuje `width`, ne padding. #}
      <td class="logo-img-cell"><img src="{{ logo_path }}" alt="logo"></td>
      <td class="logo-name">{{ supplier.display_name|default(supplier.company_name) }}</td>
    {% else %}
      <td class="logo">
        {% if logo_path and logo_path is not empty %}
          <img src="{{ logo_path }}" alt="logo" style="max-width: 72mm; max-height: 20mm;">
        {% else %}
          <div class="brand-name">{{ supplier.company_name }}</div>
        {% endif %}
      </td>
    {% endif %}
    <td class="meta">
      <div class="doc-type">{{ _doc_type }}</div>
      {% if invoice.varsymbol %}
        <div class="varsymbol-big">{{ invoice.varsymbol }}</div>
      {% endif %}
    </td>
  </tr>
</table>

<div style="margin-bottom:5mm;">
  <div class="wr-title">{{ work_report.title }}</div>
  <div style="font-size:9pt;color:#5A5470;">
    {{ t('K faktuře', 'For invoice') }} <span style="font-family:'jetbrainsmono','DejaVu Sans Mono',monospace;">{{ invoice.varsymbol }}</span>
    {% if invoice.project_name %} · {{ t('Zakázka', 'Project') }}: {{ invoice.project_name }}{% endif %}
  </div>
</div>

{% if _has_work %}
{# Cíl interního odkazu z položky práce ve faktuře (mPDF named destination). #}
<a name="work-report"></a>
<table class="items">
  <thead>
    <tr>
      <th style="width:{% if wr_has_dates %}43%{% else %}55%{% endif %}">{{ t('Popis', 'Description') }}</th>
      {% if wr_has_dates %}<th class="nowrap" style="width:12%">{{ t('Datum', 'Date') }}</th>{% endif %}
      <th class="num nowrap" style="width:13%">{{ t('Hodiny', 'Hours') }}</th>
      <th class="num nowrap" style="width:14%">{{ t('Sazba', 'Rate') }}</th>
      <th class="num nowrap" style="width:18%">{{ t('Celkem', 'Total') }}</th>
    </tr>
  </thead>
  <tbody>
    {% for it in work_report.items %}
    <tr>
      <td>{{ it.description|nl2br }}</td>
      {% if wr_has_dates %}<td class="nowrap">{% if it.work_date %}{{ it.work_date|date(date_format) }}{% endif %}</td>{% endif %}
      <td class="num nowrap">{{ it.hours|number_format(hours_dec, decimal_sep, thousand_sep) }}</td>
      <td class="num nowrap">{{ it.rate|number_format(rate_dec, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
      <td class="num nowrap">{{ it.total_amount|number_format(total_dec, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
    </tr>
    {% endfor %}
    <tr style="background:#F4F2F8;font-weight:bold;">
      <td style="text-align:right;" {% if wr_has_dates %}colspan="2"{% endif %}>{{ t('Celkem', 'Total') }}</td>
      <td class="num nowrap">{{ work_report.total_hours|number_format(hours_dec, decimal_sep, thousand_sep) }} h</td>
      <td></td>
      <td class="num nowrap">{{ work_report.total_amount|number_format(total_dec, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
    </tr>
  </tbody>
</table>
{% endif %}

{% if _has_material %}
{% set qty_dec    = (work_report.materials|filter(m => m.quantity != m.quantity|round(0))|length) > 0 ? 3 : 0 %}
{% set mprice_dec = (work_report.materials|filter(m => m.unit_price != m.unit_price|round(0))|length) > 0 ? 2 : 0 %}
{% set mtotal_dec = (work_report.materials|filter(m => m.total_amount != m.total_amount|round(0))|length) > 0 ? 2 : 0 %}
{# Cíl interního odkazu z položky materiálu ve faktuře (mPDF named destination). #}
<a name="work-report-material"></a>
<div class="wr-title" style="font-size:10pt;margin-top:{% if _has_work %}6mm{% else %}0{% endif %};margin-bottom:2mm;">{{ work_report.material_title|default(t('Materiál', 'Material')) }}</div>
<table class="items">
  <thead>
    <tr>
      <th style="width:52%">{{ t('Popis', 'Description') }}</th>
      <th class="num nowrap" style="width:13%">{{ t('Množství', 'Quantity') }}</th>
      <th class="nowrap" style="width:9%">{{ t('MJ', 'Unit') }}</th>
      <th class="num nowrap" style="width:13%">{{ t('Cena/MJ', 'Unit price') }}</th>
      <th class="num nowrap" style="width:13%">{{ t('Celkem', 'Total') }}</th>
    </tr>
  </thead>
  <tbody>
    {% for m in work_report.materials %}
    <tr>
      <td>{{ m.description|nl2br }}</td>
      <td class="num nowrap">{{ m.quantity|number_format(qty_dec, decimal_sep, thousand_sep) }}</td>
      <td class="nowrap">{{ m.unit }}</td>
      <td class="num nowrap">{{ m.unit_price|number_format(mprice_dec, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
      <td class="num nowrap">{{ m.total_amount|number_format(mtotal_dec, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
    </tr>
    {% endfor %}
    <tr style="background:#F4F2F8;font-weight:bold;">
      <td style="text-align:right;" colspan="4">{{ t('Celkem', 'Total') }}</td>
      <td class="num nowrap">{{ work_report.material_total|number_format(mtotal_dec, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
    </tr>
  </tbody>
</table>
{% endif %}

<div class="footer">
  <span class="footer-name">{{ supplier.company_name }}</span>{% if supplier.web %}<span class="footer-dot">&#160;·&#160;</span><a href="{{ supplier.web }}" class="footer-link">{{ supplier.web|replace({'https://': '', 'http://': ''})|trim('/') }}</a>{% endif %}{% if supplier.email %}<span class="footer-dot">&#160;·&#160;</span>{{ supplier.email }}{% endif %}
</div>
{% if supplier.commercial_register %}
<div class="commercial-register">{{ supplier.commercial_register }}</div>
{% endif %}
{% endif %}

</body>
</html>
