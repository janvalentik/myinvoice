{# MyInvoice.cz — PDF samostatného výkazu víceprací (Vykaz-XYZ.pdf pro schvalovací email) #}
{# Variables: invoice, supplier, work_report, locale, date_format, decimal_sep, thousand_sep, css, logo_path #}
<!doctype html>
<html lang="{{ locale|default('cs') }}">
<head>
<meta charset="utf-8">
<title></title>
<style>{{ css|raw }}</style>
</head>
<body>

{% set wr_has_dates = (work_report.items|filter(it => it.work_date)|length) > 0 %}
{# Desetinná místa per sloupec: skryj „,00" jen když jsou VŠECHNY hodnoty ve sloupci celé. #}
{% set hours_dec = (work_report.items|filter(it => it.hours != it.hours|round(0))|length) > 0 ? 2 : 0 %}
{% set rate_dec  = (work_report.items|filter(it => it.rate != it.rate|round(0))|length) > 0 ? 2 : 0 %}
{% set total_dec = (work_report.items|filter(it => it.total_amount != it.total_amount|round(0))|length) > 0 ? 2 : 0 %}

<table class="head">
  <tr>
    {% if logo_show_name and logo_path and logo_path is not empty %}
      {# Logo + název firmy — dvě sousední buňky (stejně jako faktura, kvůli mPDF). #}
      <td class="logo-img-cell"><img src="{{ logo_path }}" alt="logo"></td>
      <td class="logo-name">{{ supplier.display_name|default(supplier.company_name) }}</td>
    {% else %}
      <td class="logo">
        {% if logo_path and logo_path is not empty %}
          <img src="{{ logo_path }}" alt="logo" style="max-width: 72mm; max-height: 20mm;">
        {% else %}
          <div class="brand-name">{{ supplier.company_name }}</div>
        {% endif %}
      </td>
    {% endif %}
    <td class="meta">
      <div class="doc-type">{{ t('Výkaz víceprací — ke schválení', 'Work report — for approval') }}</div>
      {% if invoice.varsymbol %}
        <div class="varsymbol-big">{{ invoice.varsymbol }}</div>
      {% else %}
        <div class="varsymbol-big">DRAFT-{{ invoice.id }}</div>
      {% endif %}
    </td>
  </tr>
</table>

<div style="margin-bottom:5mm;">
  <div style="font-size:11pt;font-weight:bold;color:#3B2D83;margin-bottom:1mm;">{{ work_report.title }}</div>
  <div style="font-size:9pt;color:#5A5470;">
    {% if invoice.client_company_name %}
      {{ t('Pro', 'For') }}: <strong>{{ invoice.client_company_name }}</strong>
    {% endif %}
    {% if invoice.project_name %} · {{ t('Zakázka', 'Project') }}: {{ invoice.project_name }}{% endif %}
    {% if invoice.project_number %} · {{ t('Vaše číslo', 'Your order no.') }}: {{ invoice.project_number }}{% endif %}
    {% if invoice.contract_number %} · {{ t('Vaše smlouva', 'Your contract') }}: {{ invoice.contract_number }}{% endif %}
  </div>
</div>

<table class="items">
  <thead>
    <tr>
      <th style="width:{% if wr_has_dates %}43%{% else %}55%{% endif %}">{{ t('Popis', 'Description') }}</th>
      {% if wr_has_dates %}<th class="nowrap" style="width:12%">{{ t('Datum', 'Date') }}</th>{% endif %}
      <th class="num nowrap" style="width:13%">{{ t('Hodiny', 'Hours') }}</th>
      <th class="num nowrap" style="width:14%">{{ t('Sazba', 'Rate') }}</th>
      <th class="num nowrap" style="width:18%">{{ t('Celkem', 'Total') }}</th>
    </tr>
  </thead>
  <tbody>
    {% for it in work_report.items %}
    <tr>
      <td>{{ it.description|nl2br }}</td>
      {% if wr_has_dates %}<td class="nowrap">{% if it.work_date %}{{ it.work_date|date(date_format) }}{% endif %}</td>{% endif %}
      <td class="num nowrap">{{ it.hours|number_format(hours_dec, decimal_sep, thousand_sep) }}</td>
      <td class="num nowrap">{{ it.rate|number_format(rate_dec, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
      <td class="num nowrap">{{ it.total_amount|number_format(total_dec, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
    </tr>
    {% endfor %}
    <tr style="background:#F4F2F8;font-weight:bold;">
      <td style="text-align:right;" {% if wr_has_dates %}colspan="2"{% endif %}>{{ t('Celkem', 'Total') }}</td>
      <td class="num nowrap">{{ work_report.total_hours|number_format(hours_dec, decimal_sep, thousand_sep) }} h</td>
      <td></td>
      <td class="num nowrap">{{ work_report.total_amount|number_format(total_dec, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
    </tr>
  </tbody>
</table>

{% if work_report.material_total > 0 and work_report.materials|length > 0 %}
{% set qty_dec  = (work_report.materials|filter(m => m.quantity != m.quantity|round(0))|length) > 0 ? 3 : 0 %}
{% set mprice_dec = (work_report.materials|filter(m => m.unit_price != m.unit_price|round(0))|length) > 0 ? 2 : 0 %}
{% set mtotal_dec = (work_report.materials|filter(m => m.total_amount != m.total_amount|round(0))|length) > 0 ? 2 : 0 %}

<div style="margin-top:6mm;margin-bottom:2mm;font-size:10pt;font-weight:bold;color:#3B2D83;">{{ work_report.material_title|default(t('Materiál', 'Material')) }}</div>

<table class="items">
  <thead>
    <tr>
      <th style="width:52%">{{ t('Popis', 'Description') }}</th>
      <th class="num nowrap" style="width:13%">{{ t('Množství', 'Quantity') }}</th>
      <th class="nowrap" style="width:9%">{{ t('MJ', 'Unit') }}</th>
      <th class="num nowrap" style="width:13%">{{ t('Cena/MJ', 'Unit price') }}</th>
      <th class="num nowrap" style="width:13%">{{ t('Celkem', 'Total') }}</th>
    </tr>
  </thead>
  <tbody>
    {% for m in work_report.materials %}
    <tr>
      <td>{{ m.description|nl2br }}</td>
      <td class="num nowrap">{{ m.quantity|number_format(qty_dec, decimal_sep, thousand_sep) }}</td>
      <td class="nowrap">{{ m.unit }}</td>
      <td class="num nowrap">{{ m.unit_price|number_format(mprice_dec, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
      <td class="num nowrap">{{ m.total_amount|number_format(mtotal_dec, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
    </tr>
    {% endfor %}
    <tr style="background:#F4F2F8;font-weight:bold;">
      <td style="text-align:right;" colspan="4">{{ t('Celkem', 'Total') }}</td>
      <td class="num nowrap">{{ work_report.material_total|number_format(mtotal_dec, decimal_sep, thousand_sep) }} {{ invoice.currency }}</td>
    </tr>
  </tbody>
</table>
{% endif %}

<div class="footer">
  <span class="footer-name">{{ supplier.company_name }}</span>{% if supplier.web %}<span class="footer-dot">&#160;·&#160;</span><a href="{{ supplier.web }}" class="footer-link">{{ supplier.web|replace({'https://': '', 'http://': ''})|trim('/') }}</a>{% endif %}{% if supplier.email %}<span class="footer-dot">&#160;·&#160;</span>{{ supplier.email }}{% endif %}
</div>

</body>
</html>
